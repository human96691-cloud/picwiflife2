{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["!node_modules/**", "!src/**", "*/**", ".medusa/**"]
    },
    "build:plugin": {
      "dependsOn": ["^build", "@medusajs/medusa#build"],
      "outputs": ["!node_modules/**", "!src/**", ".medusa/**"]
    },
    "test": {
      "outputs": []
    },
    "test:integration": {
      "outputs": []
    },
    "test:integration:chunk": {
      "outputs": []
    }
  },
  "globalDependencies": ["turbo.json"]
}
